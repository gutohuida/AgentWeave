# Normalize line endings to LF in the repo; checkout as LF everywhere.
# This prevents CRLF noise when working across Windows/WSL/Mac.
* text=auto eol=lf

# Explicitly binary — never mangle these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
